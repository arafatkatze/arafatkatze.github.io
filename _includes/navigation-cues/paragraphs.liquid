{% assign cycles = site.data.navigation-cues.cycles | default: 6 %}{% for cycle in (1..cycles) %}<div class="paragraphs__item paragraphs__item--title js-paragraphsItem" data-index="0" data-cycle="{{ cycle }}"><strong>{{ site.data.navigation-cues.title | newline_to_br }}</strong> <small>{{ site.data.navigation-cues.byline }}</small></div><div class="paragraphs__spacer"> </div>{% for block in site.data.navigation-cues.paragraphs %}<div class="paragraphs__item js-paragraphsItem" data-index="{{ forloop.index }}" data-cycle="{{ cycle }}">{% if block.quote %}<em>{{ block.quote }}</em>{% if block.cite %} <small>{% if block.url and block.link_text %}<a href="{{ block.url }}">{{ block.link_text }}</a>{% else %}{{ block.cite }}{% endif %}</small>{% endif %}{% else %}{{ block }}{% endif %}</div><div class="paragraphs__spacer"> </div>{% endfor %}{% endfor %}
