{% assign bd_username = site.newsletter.username %}
{% if include.left %}
  {% assign bd_justify = "flex-start" %}
{% elsif include.right %}
  {% assign bd_justify = "flex-end" %}
{% else %}
  {% assign bd_justify = "center" %}
{% endif %}

<div
  class="newsletter-form-container"
  {% if include.center %}
    style="margin: 20px"
  {% endif %}
>
  {% comment %}
    Posts directly to Buttondown's public embed endpoint (no API key, no
    backend). The popup target keeps this page in place and shows Buttondown's
    confirmation in a small window. See https://docs.buttondown.com.
  {% endcomment %}
  <form
    class="newsletter-form"
    action="https://buttondown.com/api/emails/embed-subscribe/{{ bd_username }}"
    method="post"
    target="popupwindow"
    onsubmit="window.open('https://buttondown.com/{{ bd_username }}', 'popupwindow')"
    style="justify-content: {{ bd_justify }}"
  >
    <input
      class="newsletter-form-input"
      name="email"
      type="email"
      placeholder="user@example.com"
      autocomplete="email"
      required=""
    >

    <input type="hidden" name="embed" value="1">

    <button type="submit" class="newsletter-form-button" style="justify-content: {{ bd_justify }}">
      subscribe
    </button>
  </form>
</div>
