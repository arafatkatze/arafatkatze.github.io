<div class="repo p-2 w-100">
  <a class="text-decoration-none text-reset" href="https://github.com/{{ include.username }}">
    <div class="card h-100">
      <div class="card-body d-flex align-items-center gap-3 text-start">
        <img
          class="rounded-circle flex-shrink-0"
          src="https://github.com/{{ include.username }}.png?size=160"
          alt="{{ include.username }}"
          width="72"
          height="72"
          loading="lazy"
        >
        <div>
          <h5 class="card-title mb-1">@{{ include.username }}</h5>
          <p class="card-text text-muted mb-3">GitHub profile</p>
          <span class="badge rounded-pill bg-secondary">Open profile</span>
        </div>
      </div>
    </div>
  </a>
</div>
