<div class="repo p-2 w-100">
  <a class="text-decoration-none text-reset" href="https://github.com/{{ include.username }}?tab=achievements">
    <div class="card h-100">
      <div class="card-body text-start">
        <h5 class="card-title mb-1">
          <i class="fa-solid fa-trophy me-2" aria-hidden="true"></i>GitHub achievements
        </h5>
        <p class="card-text text-muted mb-3">Open {{ include.username }} achievements on GitHub.</p>
        <span class="badge rounded-pill bg-secondary">Open achievements</span>
      </div>
    </div>
  </a>
</div>
