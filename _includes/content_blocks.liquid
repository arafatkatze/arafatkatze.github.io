{% comment %}
  Bento grid — chester.how-style tile mosaic for the front page.
  Tiles are defined in page.bento_tiles front matter.
{% endcomment %}

{% comment %}
  Each tile pops in a different direction on hover. A tile can set its own
  direction with `pop:` in front matter (pop-up, pop-down, pop-left,
  pop-right, pop-zoom, pop-tilt); otherwise we cycle through the variants so
  adjacent tiles animate differently.
{% endcomment %}
{% assign pop_cycle = "pop-up,pop-left,pop-zoom,pop-down,pop-right,pop-tilt" | split: "," %}
<div class="bento-grid">
  {% for tile in page.bento_tiles %}
    {% if tile.pop %}
      {% assign pop_class = tile.pop %}
    {% else %}
      {% assign pop_index = forloop.index0 | modulo: 6 %}
      {% assign pop_class = pop_cycle[pop_index] %}
    {% endif %}
    <a
      class="bento-tile {{ tile.type | default: 'image' }} {{ pop_class }} {% if tile.span %}span-{{ tile.span }}{% endif %} {% if tile.bg %}bg-{{ tile.bg }}{% endif %}"
      href="{{ tile.link | relative_url }}"
      {% if tile.style %}style="{{ tile.style }}"{% endif %}
    >
      {% if tile.image %}
        <div class="bento-tile-img">
          {% if tile.image contains '://' %}
            {% assign tile_img_src = tile.image %}
          {% else %}
            {% assign tile_img_src = tile.image | relative_url %}
          {% endif %}
          <img src="{{ tile_img_src }}" alt="{{ tile.title }}" loading="{% if forloop.index <= 4 %}eager{% else %}lazy{% endif %}"{% if tile.image_dark %} class="tile-img-light"{% endif %} />
          {% if tile.image_dark %}
            {% if tile.image_dark contains '://' %}
              {% assign tile_img_dark_src = tile.image_dark %}
            {% else %}
              {% assign tile_img_dark_src = tile.image_dark | relative_url %}
            {% endif %}
            <img src="{{ tile_img_dark_src }}" alt="{{ tile.title }}" loading="{% if forloop.index <= 4 %}eager{% else %}lazy{% endif %}" class="tile-img-dark" />
          {% endif %}
        </div>
      {% endif %}

      {% if tile.type == 'text' or tile.type == 'card' %}
        <div class="bento-tile-body">
          {% if tile.label %}
            <span class="bento-tile-label">{{ tile.label }}</span>
          {% endif %}
          <span class="bento-tile-arrow">&#8599;</span>
          {% if tile.title %}
            <h3 class="bento-tile-title">{{ tile.title }}</h3>
          {% endif %}
          {% if tile.excerpt %}
            <p class="bento-tile-excerpt">{{ tile.excerpt }}</p>
          {% endif %}
        </div>

      {% elsif tile.type == 'book' %}
        <div class="bento-tile-book-info">
          {% if tile.label %}
            <span class="bento-tile-label">{{ tile.label }}</span>
          {% endif %}
          <span class="bento-tile-arrow">&#8599;</span>
          {% if tile.badge %}
            <span class="bento-tile-badge {% if tile.badge == 'Favorite' %}badge-fav{% elsif tile.badge == 'Reading' %}badge-reading{% else %}badge-read{% endif %}">{{ tile.badge }}</span>
          {% endif %}
          <span class="bento-tile-book-title">{{ tile.title }}</span>
          {% if tile.author %}
            <span class="bento-tile-book-author">{{ tile.author }}</span>
          {% endif %}
        </div>

      {% else %}
        <div class="bento-tile-overlay">
          {% if tile.label %}
            <span class="bento-tile-label">{{ tile.label }}</span>
          {% endif %}
          <span class="bento-tile-arrow">&#8599;</span>
          {% if tile.title and tile.show_title != false %}
            <h3 class="bento-tile-title">{{ tile.title }}</h3>
          {% endif %}
        </div>
      {% endif %}
    </a>
  {% endfor %}
</div>
