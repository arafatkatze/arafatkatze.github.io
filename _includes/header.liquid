<header>
  <nav id="navbar" class="navbar navbar-light navbar-expand-sm {% if site.navbar_fixed %}fixed-top{% else %}sticky-top{% endif %}" role="navigation">
    <div class="container">
      <!-- Brand wordmark -->
      <a class="navbar-brand" href="{{ '/' | relative_url }}" aria-label="ara — home">
        <img src="{{ '/assets/img/wordmark.svg' | relative_url }}" alt="ara." class="navbar-brand-mark" />
      </a>

      <!-- Navbar Toggle (mobile) -->
      <button
        class="navbar-toggler collapsed ml-auto"
        type="button"
        data-toggle="collapse"
        data-target="#navbarNav"
        aria-controls="navbarNav"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <span class="sr-only">Toggle navigation</span>
        <span class="icon-bar top-bar"></span>
        <span class="icon-bar middle-bar"></span>
        <span class="icon-bar bottom-bar"></span>
      </button>

      <div class="collapse navbar-collapse" id="navbarNav">
        <div class="pill-nav-row">
          <div class="pill-nav-wrapper">
            {% for page_item in site.pages %}
              {% if page_item.permalink == '/' %}
                {% assign about_title = page_item.title %}
              {% endif %}
            {% endfor %}

            <!-- About / Home -->
            <a class="pill-nav-link {% if page.permalink == '/' %}active{% endif %}" href="{{ '/' | relative_url }}">
              {{- about_title -}}
            </a>

            <!-- Other pages -->
            {% assign sorted_pages = site.pages | sort: 'nav_order' %}
            {% for p in sorted_pages %}
              {% if p.nav and p.autogen == null %}
                {% assign parent_link = p.permalink | remove: 'index.html' %}
                {%- if p.permalink contains '://' -%}
                  {%- assign url = p.permalink -%}
                {%- elsif p.permalink contains '/blog/' -%}
                  {%- assign url = '/blog/' -%}
                {%- else -%}
                  {%- assign url = p.url -%}
                {%- endif %}
                <a class="pill-nav-link {% if page.url contains parent_link %}active{% endif %}" href="{{ url | relative_url }}">
                  {{- p.title -}}
                </a>
              {% endif %}
            {% endfor %}
          </div>

          <div class="pill-nav-actions">
            {% if site.search_enabled %}
              <button id="search-toggle" class="pill-nav-icon" title="Search" aria-label="Open search" onclick="openSearchModal()">
                <i class="ti ti-search" aria-hidden="true"></i>
              </button>
            {% endif %}
            {% if site.enable_darkmode %}
              <button id="light-toggle" class="pill-nav-icon" title="Change theme" aria-label="Toggle light, dark, or system theme">
                <i class="ti ti-sun-moon" id="light-toggle-system" aria-hidden="true"></i>
                <i class="ti ti-moon-filled" id="light-toggle-dark" aria-hidden="true"></i>
                <i class="ti ti-sun-filled" id="light-toggle-light" aria-hidden="true"></i>
              </button>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </nav>
  {% if site.enable_progressbar %}
    <progress id="progress" value="0">
      <div class="progress-container">
        <span class="progress-bar"></span>
      </div>
    </progress>
  {% endif %}
</header>
