<!-- Color Scheme Picker — only rendered on the front/about page -->
<div class="color-scheme-picker" id="color-scheme-picker" aria-label="Color scheme picker">
  <button class="color-dot" data-scheme="purple" style="--dot-color: #b509ac" title="Purple" aria-label="Purple color scheme"></button>
  <button class="color-dot" data-scheme="rose" style="--dot-color: #e11d48" title="Rose" aria-label="Rose color scheme"></button>
  <button class="color-dot" data-scheme="red" style="--dot-color: #dc2626" title="Red" aria-label="Red color scheme"></button>
  <button class="color-dot" data-scheme="orange" style="--dot-color: #ea580c" title="Orange" aria-label="Orange color scheme"></button>
  <button class="color-dot" data-scheme="amber" style="--dot-color: #d97706" title="Amber" aria-label="Amber color scheme"></button>
  <button class="color-dot" data-scheme="green" style="--dot-color: #16a34a" title="Green" aria-label="Green color scheme"></button>
  <button class="color-dot" data-scheme="teal" style="--dot-color: #0d9488" title="Teal" aria-label="Teal color scheme"></button>
  <button class="color-dot" data-scheme="blue" style="--dot-color: #2563eb" title="Blue" aria-label="Blue color scheme"></button>
  <button class="color-dot" data-scheme="indigo" style="--dot-color: #4f46e5" title="Indigo" aria-label="Indigo color scheme"></button>
  <button class="color-dot" data-scheme="slate" style="--dot-color: #475569" title="Slate" aria-label="Slate color scheme"></button>
</div>
