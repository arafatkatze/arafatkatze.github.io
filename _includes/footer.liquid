{% if site.footer_fixed %}
  <footer class="fixed-bottom" role="contentinfo">
    <div class="container mt-0">
      &copy; {{ site.time | date: '%Y' }} {{ site.first_name }} {{ site.middle_name }} {{ site.last_name }}.
      {% if site.footer_text %} {{ site.footer_text }}{% endif %}
    </div>
  </footer>
{% else %}
  <footer class="sticky-bottom mt-5" role="contentinfo">
    {% if site.newsletter.enabled %}
      {% include newsletter.liquid %}
    {% endif %}

    <div class="container site-footer">
      <div class="site-footer__grid">

        <div class="site-footer__col site-footer__brand">
          <a href="{{ '/' | relative_url }}" class="site-footer__wordmark" aria-label="ara — home">
            <img src="{{ '/assets/img/wordmark.svg' | relative_url }}" alt="ara." />
          </a>
          <p class="site-footer__tag">at the intersection of art, love, and beauty.</p>
          {% assign w_current = site.data.whereami.current %}
          {% if w_current %}
            <p class="site-footer__loc">
              <a href="{{ '/where-is-ara/' | relative_url }}" class="site-footer__here">
                <span class="site-footer__here-dot"></span>
                {{ w_current.city }}, {{ w_current.country }}
              </a>
              · {{ site.time | date: '%Y' }}
            </p>
          {% else %}
            <p class="site-footer__loc">San Francisco, CA · {{ site.time | date: '%Y' }}</p>
          {% endif %}
        </div>

        <div class="site-footer__col">
          <h4 class="site-footer__head">Wander</h4>
          <ul class="site-footer__list">
            <li><a href="{{ '/blog/'        | relative_url }}">Writing</a></li>
            <li><a href="{{ '/projects/'    | relative_url }}">Projects</a></li>
            <li><a href="{{ '/reading/'     | relative_url }}">Reading</a></li>
            <li><a href="{{ '/travel/'      | relative_url }}">Travel</a></li>
            <li><a href="{{ '/photos/'      | relative_url }}">Photos</a></li>
            <li><a href="{{ '/pixels/'      | relative_url }}">Pixel Board</a></li>
            <li><a href="{{ '/guestbook/'   | relative_url }}">Guestbook</a></li>
            <li><a href="{{ '/fortune/'     | relative_url }}">Fortune</a></li>
            <li><a href="{{ '/where-is-ara/'| relative_url }}">Where is Ara</a></li>
            <li><a href="{{ '/this-week/'   | relative_url }}">This week</a></li>
            <li><a href="{{ '/letters-to-strangers/' | relative_url }}">Letters to strangers</a></li>
            <li><a href="{{ '/atomic-letter/' | relative_url }}">Atomic letter</a></li>
            <li><a href="{{ '/sunset/'      | relative_url }}">Sunset</a></li>
            <li><a href="{{ '/words-i-underline/' | relative_url }}">Words I underline</a></li>
            <li><a href="{{ '/moon/'        | relative_url }}">Moon</a></li>
            <li><a href="{{ '/pack/'        | relative_url }}">Pack My Suitcase</a></li>
            <li><a href="{{ '/repositories/'| relative_url }}">Open source</a></li>
            <li><a href="{{ '/start-here/'  | relative_url }}">Start here</a></li>
            <li><a href="{{ '/now/'         | relative_url }}">Now</a></li>
            <li><a href="{{ '/uses/'        | relative_url }}">Uses</a></li>
            <li><a href="{{ '/colophon/'    | relative_url }}">Colophon</a></li>
          </ul>
        </div>

        <div class="site-footer__col">
          <h4 class="site-footer__head">Stay in touch</h4>
          <ul class="site-footer__list">
            <li><a href="mailto:{{ site.email | encode_email }}" rel="me">Email</a></li>
            {% if site.twitter_username %}
              <li><a href="https://twitter.com/{{ site.twitter_username }}" rel="me noopener" target="_blank">Twitter</a></li>
            {% endif %}
            {% if site.github_username %}
              <li><a href="https://github.com/{{ site.github_username }}" rel="me noopener" target="_blank">GitHub</a></li>
            {% endif %}
            {% if site.instagram_id %}
              <li><a href="https://instagram.com/{{ site.instagram_id }}" rel="me noopener" target="_blank">Instagram</a></li>
            {% endif %}
            {% if site.linkedin_username %}
              <li><a href="https://www.linkedin.com/in/{{ site.linkedin_username }}" rel="me noopener" target="_blank">LinkedIn</a></li>
            {% endif %}
            <li><a href="{{ '/feed.xml' | relative_url }}">RSS</a></li>
          </ul>
        </div>
      </div>

      <div class="site-footer__base">
        <span>&copy; {{ site.time | date: '%Y' }} {{ site.first_name }} {{ site.last_name }}</span>
        <span class="dot">·</span>
        <span>built with care in <a href="https://jekyllrb.com/">Jekyll</a></span>
        {% if site.last_updated %}
          <span class="dot">·</span>
          <span>last updated {{ 'now' | date: '%-d %b %Y' }}</span>
        {% endif %}
        {% if site.impressum_path %}
          <span class="dot">·</span>
          <a href="{{ site.url }}{{ site.baseurl }}{{ site.impressum_path }}">Impressum</a>
        {% endif %}
      </div>
    </div>
  </footer>
{% endif %}

<!-- Floating Contact Button (appears on all pages) -->
{% include contact_form.liquid %}
