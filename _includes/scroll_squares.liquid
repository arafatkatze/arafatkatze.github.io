{% comment %}
  Scroll Squares — jesschase.com-inspired horizontal scroll strip.
  Tiles defined in page.scroll_squares front matter.
{% endcomment %}

<section class="scroll-squares-section">
  <div class="scroll-squares-track" id="scrollSquaresTrack">
    {% for sq in page.scroll_squares %}
      <a class="scroll-square" href="{{ sq.link | relative_url }}" style="--sq-accent: {{ sq.accent | default: 'rgba(0,0,0,0.4)' }}">
        {% if sq.image %}
          <img
            class="scroll-square-bg"
            src="{{ sq.image }}"
            alt="{{ sq.title }}"
            loading="{% if forloop.index <= 4 %}eager{% else %}lazy{% endif %}"
          />
        {% endif %}
        <div class="scroll-square-overlay">
          {% if sq.label %}
            <span class="scroll-square-label">{{ sq.label }}</span>
          {% endif %}
          <h3 class="scroll-square-title">{{ sq.title }}</h3>
        </div>
      </a>
    {% endfor %}
  </div>

  <button class="scroll-squares-arrow scroll-squares-arrow--left" id="scrollSquaresLeft" aria-label="Scroll left">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
  </button>
  <button class="scroll-squares-arrow scroll-squares-arrow--right" id="scrollSquaresRight" aria-label="Scroll right">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
  </button>

  <div class="scroll-squares-dots" id="scrollSquaresDots">
    {% for sq in page.scroll_squares %}
      <span class="scroll-squares-dot {% if forloop.first %}active{% endif %}"></span>
    {% endfor %}
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function () {
  var track = document.getElementById('scrollSquaresTrack');
  var leftBtn = document.getElementById('scrollSquaresLeft');
  var rightBtn = document.getElementById('scrollSquaresRight');
  var dots = document.querySelectorAll('#scrollSquaresDots .scroll-squares-dot');
  if (!track) return;

  var scrollAmount = 320;

  function updateArrows() {
    var atStart = track.scrollLeft <= 8;
    var atEnd = track.scrollLeft + track.clientWidth >= track.scrollWidth - 8;
    leftBtn.style.opacity = atStart ? '0' : '1';
    leftBtn.style.pointerEvents = atStart ? 'none' : 'auto';
    rightBtn.style.opacity = atEnd ? '0' : '1';
    rightBtn.style.pointerEvents = atEnd ? 'none' : 'auto';
  }

  function updateDots() {
    var squares = track.querySelectorAll('.scroll-square');
    var trackRect = track.getBoundingClientRect();
    var center = trackRect.left + trackRect.width / 2;
    var closestIdx = 0;
    var closestDist = Infinity;
    squares.forEach(function (sq, i) {
      var rect = sq.getBoundingClientRect();
      var sqCenter = rect.left + rect.width / 2;
      var dist = Math.abs(sqCenter - center);
      if (dist < closestDist) {
        closestDist = dist;
        closestIdx = i;
      }
    });
    dots.forEach(function (d, i) {
      d.classList.toggle('active', i === closestIdx);
    });
  }

  leftBtn.addEventListener('click', function () {
    track.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
  });
  rightBtn.addEventListener('click', function () {
    track.scrollBy({ left: scrollAmount, behavior: 'smooth' });
  });

  track.addEventListener('scroll', function () {
    updateArrows();
    updateDots();
  }, { passive: true });

  updateArrows();
});
</script>
